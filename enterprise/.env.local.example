# =============================================================================
# AgenticX Enterprise — 本地开发环境变量模板
# =============================================================================
#
# 推荐流程（不必手动 copy 本文件）：
#   cd enterprise && bash scripts/bootstrap.sh
# bootstrap 会生成本地可用的 enterprise/.env.local（chmod 600，已在 .gitignore）。
#
# 手动流程（仅当不用 bootstrap 时）：
#   cp .env.local.example .env.local
#   按注释替换占位值；PEM / token 建议放 .local-secrets/，在 .env.local 里写 *_FILE 路径。
#
# 改完任意 env 后须完整重启 start-dev / start-dev-with-infra，Next.js 不会热加载 SSO 等变量。
# 变量总表：docs/configuration/env-vars.md
# =============================================================================

# --- 1. 数据库（必填）---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/agenticx

# --- 2. 管理台 / 前台登录（local dev）---
ADMIN_CONSOLE_LOGIN_EMAIL=admin@agenticx.local
ADMIN_CONSOLE_LOGIN_PASSWORD=change-me
ADMIN_CONSOLE_SESSION_SECRET=replace-with-random-session-secret

AUTH_DEV_OWNER_PASSWORD=change-me
ENABLE_DEV_BOOTSTRAP=true

# bootstrap 写入 seed 后的默认租户/部门 ULID（跑完 bootstrap 后可在 .env.local 里看到真实值）
DEFAULT_TENANT_ID=
DEFAULT_DEPT_ID=

# --- 3. JWT（必填；PEM 多行勿直接写进本文件，用 *_FILE）---
AUTH_JWT_PRIVATE_KEY_FILE=.local-secrets/auth_private.pem
AUTH_JWT_PUBLIC_KEY_FILE=.local-secrets/auth_public.pem

# --- 4. Gateway 基础（local 默认端口 8088）---
GATEWAY_BASE_URL=http://127.0.0.1:8088
GATEWAY_COMPLETIONS_URL=http://127.0.0.1:8088/v1/chat/completions

# Gateway ↔ Admin internal API 共用 Bearer；bootstrap 生成到 .local-secrets/gateway_internal.token
GATEWAY_INTERNAL_TOKEN_FILE=.local-secrets/gateway_internal.token

# admin-console 调 gateway internal 管理面（插件/错误指纹/Channel 探活）；默认代码 fallback 8080，本地须写 8088
GATEWAY_INTERNAL_BASE_URL=http://127.0.0.1:8088

# Gateway 从 admin 拉运行时配置（local bootstrap 默认指向 :3001）
GATEWAY_REMOTE_PROVIDERS_URL=http://127.0.0.1:3001/api/internal/providers
GATEWAY_REMOTE_QUOTA_CONFIG_URL=http://127.0.0.1:3001/api/internal/quotas
GATEWAY_REMOTE_POLICY_SNAPSHOT_URL=http://127.0.0.1:3001/api/internal/policy-snapshot
GATEWAY_REMOTE_CHANNELS_URL=http://127.0.0.1:3001/api/internal/channels

# Channel 中继 + 探活（enterprise-gateway multi-protocol / wasm 验收建议开启）
GATEWAY_CHANNEL_REGISTRY=on

# MCP 托管（/mcp/*、admin /admin/mcp-servers）；须显式 on
GATEWAY_MCP_HOSTING=on

# --- 4.1 Gateway 可选开关（代码里多数默认已开，写上便于排查）---
# GATEWAY_WASM_PLUGINS=on
# GATEWAY_CACHE_L1=on
# GATEWAY_CACHE_L2=off
# GATEWAY_METRICS=on
# GATEWAY_INBOUND_CLAUDE=on
# GATEWAY_INBOUND_GEMINI=on
# GATEWAY_INBOUND_RESPONSES=on

# --- 4.2 性能剖析（仅本地装了 Pyroscope 时需要）---
# GATEWAY_PYROSCOPE=on
# PYROSCOPE_URL=http://127.0.0.1:4040

# --- 5. Admin 加密密钥（生产必填；local 未设时用 dev 兜底，不建议提交真实值）---
# AGX_PROVIDER_SECRET_KEY=replace-with-openssl-rand-base64-32
# SSO_PROVIDER_SECRET_KEY 见下方 SSO 段

# --- 6. 上游模型 Key 备选（admin GUI 已配置时可省略）---
# DEEPSEEK_API_KEY=sk-...
# LLM_API_KEY=sk-...

# --- 7. 本地 migrate（默认 start-dev.sh 对 localhost DB 自动 migrate）---
# AGX_AUTO_DB_MIGRATE=1

# =============================================================================
# SSO（portal + admin）
# =============================================================================

NEXT_PUBLIC_SSO_PROVIDERS=default:企业统一认证
SSO_STATE_SIGNING_SECRET=replace-with-32-plus-bytes-random-secret
SSO_RETURN_TO_ALLOWLIST=/workspace,/dashboard
SSO_DEFAULT_ROLE_CODES=member
SSO_JIT_ROLE_ALLOWLIST=member,admin

SSO_OIDC_DEFAULT_ISSUER=https://idp.example.com/realms/agenticx
SSO_OIDC_DEFAULT_CLIENT_ID=agenticx-portal
SSO_OIDC_DEFAULT_CLIENT_SECRET=replace-with-client-secret
SSO_OIDC_DEFAULT_REDIRECT_URI=http://localhost:3000/api/auth/sso/oidc/callback
SSO_OIDC_DEFAULT_ADMIN_REDIRECT_URI=http://localhost:3001/api/auth/sso/oidc/callback
SSO_OIDC_DEFAULT_SCOPES=openid profile email groups
SSO_OIDC_DEFAULT_CLAIM_EMAIL=email
SSO_OIDC_DEFAULT_CLAIM_NAME=name
SSO_OIDC_DEFAULT_CLAIM_DEPT=department
SSO_OIDC_DEFAULT_CLAIM_ROLES=groups
SSO_OIDC_DEFAULT_CLAIM_EXTERNAL_ID=sub

# 可选：收紧 redirect_uri（admin-console 保存 provider 时校验）
# NEXT_PUBLIC_SSO_REDIRECT_ORIGIN_ALLOWLIST=http://localhost:3000,http://localhost:3001
# SSO_REDIRECT_REQUIRE_ISSUER_ORIGIN_MATCH=true
# 开发态非本机 http redirect 白名单（逗号分隔 origin），生产勿用
# SSO_DEV_INSECURE_REDIRECT_ALLOWLIST=

# Phase 4 provider secret encryption
SSO_PROVIDER_SECRET_KEY=replace-with-32-plus-byte-encryption-key

# SAML 双栈一键回退开关（仅关 SAML，不影响 OIDC）。
# 默认 false；设为 true 后 portal/admin 的 /api/auth/sso/saml/* 立即返回 saml.provider_not_configured，
# 同时管理台「新增 SAML provider」会被拒绝创建。详见 docs/runbooks/sso-saml-setup.md。
SSO_SAML_DISABLED=false

# 建议使用 openssl 生成:
# openssl rand -base64 32

# ============================================================
# 中移动 IDaaS（OIDC）接入模板
# ------------------------------------------------------------
# 实际对接前请向客户索取以下信息（M0 信息收集清单见
# docs/runbooks/sso-oidc-setup.md「中移动 IDaaS 接入信息收集清单」）。
# 客户尚未给出真实 issuer 时，请保留默认 https://idp.example.com 占位值，
# 让登录页稳定显示 `oidc.provider_not_configured` 错误码，避免误触 OIDC discovery。
# ------------------------------------------------------------
# NEXT_PUBLIC_SSO_PROVIDERS=cmcc-idaas:中移动统一身份
# SSO_OIDC_CMCC_IDAAS_ISSUER=https://<cmcc-idaas-host>/oauth2
# SSO_OIDC_CMCC_IDAAS_CLIENT_ID=<cmcc-idaas-client-id>
# SSO_OIDC_CMCC_IDAAS_CLIENT_SECRET=<cmcc-idaas-client-secret>
# SSO_OIDC_CMCC_IDAAS_REDIRECT_URI=http://localhost:3000/api/auth/sso/oidc/callback
# SSO_OIDC_CMCC_IDAAS_ADMIN_REDIRECT_URI=http://localhost:3001/api/auth/sso/oidc/callback
# SSO_OIDC_CMCC_IDAAS_SCOPES=openid profile email
# SSO_OIDC_CMCC_IDAAS_CLAIM_EMAIL=email
# SSO_OIDC_CMCC_IDAAS_CLAIM_NAME=name
# SSO_OIDC_CMCC_IDAAS_CLAIM_DEPT=department
# SSO_OIDC_CMCC_IDAAS_CLAIM_ROLES=roles
# SSO_OIDC_CMCC_IDAAS_CLAIM_EXTERNAL_ID=sub
# ============================================================
