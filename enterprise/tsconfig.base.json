{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@agenticx/ui": ["packages/ui/src/index.ts"],
      "@agenticx/ui/*": ["packages/ui/src/*"],
      "@agenticx/branding": ["packages/branding/src/index.ts"],
      "@agenticx/auth": ["packages/auth/src/index.ts"],
      "@agenticx/auth/*": ["packages/auth/src/*"],
      "@agenticx/db-schema": ["packages/db-schema/src/index.ts"],
      "@agenticx/core-api": ["packages/core-api/src/index.ts"],
      "@agenticx/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@agenticx/sdk-ts": ["packages/sdk-ts/src/index.ts"],
      "@agenticx/config": ["packages/config/src/index.ts"],
      "@agenticx/telemetry": ["packages/telemetry/src/index.ts"],
      "@agenticx/feature-iam": ["features/iam/src/index.ts"],
      "@agenticx/feature-chat": ["features/chat/src/index.ts"],
      "@agenticx/feature-model-service": ["features/model-service/src/index.ts"],
      "@agenticx/feature-knowledge-base": ["features/knowledge-base/src/index.ts"],
      "@agenticx/feature-tools-mcp": ["features/tools-mcp/src/index.ts"],
      "@agenticx/feature-agents": ["features/agents/src/index.ts"],
      "@agenticx/feature-metering": ["features/metering/src/index.ts"],
      "@agenticx/feature-audit": ["features/audit/src/index.ts"],
      "@agenticx/feature-policy": ["features/policy/src/index.ts"],
      "@agenticx/feature-settings": ["features/settings/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "**/dist", "**/build", "**/.next", "**/out"]
}
